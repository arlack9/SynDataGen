# Julius.ai API Configuration
# Add these environment variables to your .env file

# Julius.ai API Key - Get this from your Julius.ai dashboard
JULIUS_AI_API_KEY=your_julius_ai_api_key_here

# Julius.ai API Base URL (default: https://api.julius.ai/v1)
JULIUS_AI_BASE_URL=https://api.julius.ai/v1

# Your application URL for identification
APP_URL=http://localhost:5000

# Optional: Enable Julius.ai API usage (true/false)
JULIUS_AI_ENABLED=true

# Optional: Julius.ai request timeout in seconds (default: 30)
JULIUS_AI_TIMEOUT=30

# Optional: Julius.ai rate limit handling (default: true)
JULIUS_AI_AUTO_FALLBACK=true
